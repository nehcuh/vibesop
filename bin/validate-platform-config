#!/usr/bin/env ruby
# frozen_string_literal: true

# Platform Configuration Validator
# Validates config/platforms.yaml using JSON Schema and extra integrity checks.

require 'json'
require 'yaml'
begin
  require 'json-schema'
rescue LoadError
  warn 'Missing dependency: json-schema'
  warn 'Run: bundle install'
  exit 2
end

ROOT = File.expand_path('..', __dir__)
SCHEMA_PATH = File.join(ROOT, 'config', 'schemas', 'platform_config.schema.json')
CONFIG_PATH = File.join(ROOT, 'config', 'platforms.yaml')

def format_error(error)
  fragment = error[:fragment] || error['fragment'] || '#'
  message = error[:message] || error['message'] || error.inspect
  "#{fragment}: #{message}"
end

def validate_platform_config
  puts '🔍 Validating platform configuration...'
  puts "   Schema: #{SCHEMA_PATH}"
  puts "   Config: #{CONFIG_PATH}"
  puts

  config = YAML.safe_load(File.read(CONFIG_PATH), aliases: true)
  puts '✅ Configuration loaded successfully'
  puts "   Platforms defined: #{config.fetch('platforms', {}).keys.size}"
  puts

  schema_errors = JSON::Validator.fully_validate(
    SCHEMA_PATH,
    config,
    errors_as_objects: true
  )

  alias_errors = []
  aliases = config['aliases']
  platforms = config.fetch('platforms', {})
  if aliases.is_a?(Hash)
    aliases.each do |alias_name, target|
      next if platforms.key?(target)

      alias_errors << {
        fragment: "#/aliases/#{alias_name}",
        message: "Alias '#{alias_name}' points to non-existent platform '#{target}'"
      }
    end
  end

  errors = schema_errors + alias_errors

  puts "\n#{'=' * 60}"
  if errors.empty?
    puts '✅ Validation passed successfully!'
    puts "\nSummary:"
    puts "  Platforms: #{config.fetch('platforms', {}).keys.size}"
    puts "  Aliases: #{config.fetch('aliases', {}).keys.size}"
    puts '  Errors: 0'
    true
  else
    puts '❌ Validation failed!'
    puts "\nErrors found (#{errors.size}):"
    errors.each_with_index do |error, index|
      puts "  #{index + 1}. #{format_error(error)}"
    end
    false
  end
rescue StandardError => e
  puts "❌ Validation crashed: #{e.class} - #{e.message}"
  false
end

success = validate_platform_config
exit(success ? 0 : 1)
