#!/usr/bin/env ruby
# frozen_string_literal: true

# Validate YAML files against JSON Schema
# Usage: bin/validate-schemas

require 'json'
require 'yaml'
begin
  require 'json-schema'
rescue LoadError
  warn 'Missing dependency: json-schema'
  warn 'Run: bundle install'
  exit 2
end

SCHEMA_DIR = File.join(__dir__, '..', 'schemas')
CORE_DIR = File.join(__dir__, '..', 'core')

VALIDATIONS = [
  {
    schema: File.join(SCHEMA_DIR, 'providers.schema.json'),
    yaml: File.join(CORE_DIR, 'models', 'providers.yaml')
  },
  {
    schema: File.join(SCHEMA_DIR, 'skills.schema.json'),
    yaml: File.join(CORE_DIR, 'skills', 'registry.yaml')
  },
  {
    schema: File.join(SCHEMA_DIR, 'security.schema.json'),
    yaml: File.join(CORE_DIR, 'security', 'policy.yaml')
  }
].freeze

def format_error(error)
  fragment = error[:fragment] || error['fragment'] || '#'
  message = error[:message] || error['message'] || error.inspect
  "#{fragment}: #{message}"
end

def validate_file(yaml_path, schema_path)
  data = YAML.safe_load(File.read(yaml_path), aliases: true)
  errors = JSON::Validator.fully_validate(
    schema_path,
    data,
    errors_as_objects: true
  )

  if errors.empty?
    puts "✓ #{yaml_path}"
    true
  else
    puts "✗ #{yaml_path}"
    errors.each { |error| puts "  - #{format_error(error)}" }
    false
  end
rescue StandardError => e
  puts "✗ #{yaml_path}: #{e.message}"
  false
end

# Main validation - only for schemas that exist
puts '🔍 Validating YAML files against schemas...'
puts

all_valid = true
VALIDATIONS.each do |entry|
  all_valid &= validate_file(entry[:yaml], entry[:schema])
end

puts
if all_valid
  puts '✅ All schema validations passed.'
  exit 0
else
  puts '❌ Some schema validations failed.'
  exit 1
end
