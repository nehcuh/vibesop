# Environment Configuration for AI-Powered Skill Routing
# Copy this file to .env and configure your values

# ============================================================================
# ANTHROPIC API Configuration (REQUIRED)
# ============================================================================

# Your Anthropic API Key
# Get yours from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Custom API base URL (for testing or proxy)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ============================================================================
# AI TRIAGE CONFIGURATION
# ============================================================================

# Enable/disable AI-powered skill routing (default: true)
# Set to 'false' to fall back to algorithm-only routing
VIBE_AI_TRIAGE_ENABLED=true

# Model to use for semantic triage (default: claude-haiku-4-5-20251001)
# Options: claude-haiku-4-5-20251001, claude-sonnet-4-6, claude-opus-4-6
# Note: Using larger models will increase cost and latency
VIBE_TRIAGE_MODEL=claude-haiku-4-5-20251001

# Cache TTL in seconds (default: 86400 = 24 hours)
# How long to cache triage results before re-evaluating
VIBE_TRIAGE_CACHE_TTL=86400

# Minimum confidence threshold for AI recommendations (default: 0.7)
# Skills with confidence below this threshold will not be recommended
# Range: 0.0 - 1.0
VIBE_TRIAGE_CONFIDENCE=0.7

# Request timeout in seconds (default: 5)
# Maximum time to wait for AI response before falling back
VIBE_TRIAGE_TIMEOUT=5

# Maximum requests per hour (default: 100)
# Rate limiting to prevent cost overruns
# Set to 0 for unlimited (not recommended)
VIBE_TRIAGE_MAX_REQUESTS=100

# ============================================================================
# REDIS CACHE CONFIGURATION (OPTIONAL)
# ============================================================================

# Redis URL for Level 3 distributed caching (optional)
# Leave empty to skip Redis and use only Memory + File cache
# Format: redis://localhost:6379/0 or redis://user:pass@localhost:6379/0
REDIS_URL=

# Redis key prefix for VibeSOP cache entries (default: vibesop:ai_triage:)
# Helps avoid key collisions in shared Redis instances
REDIS_KEY_PREFIX=vibesop:ai_triage:

# ============================================================================
# MONITORING AND LOGGING
# ============================================================================

# Enable detailed logging (default: false)
# Set to 'true' for debugging or development
VIBE_LOG_LEVEL=info

# Enable cost monitoring (default: true)
# Track API usage and costs in real-time
VIBE_COST_MONITORING=true

# Enable error alerting (default: true)
# Send alerts when error rate or costs exceed thresholds
VIBE_ERROR_ALERTING=true

# ============================================================================
# DEVELOPMENT AND TESTING
# ============================================================================

# Force AI triage even in development (default: true)
# Set to 'false' to test algorithm-only routing during development
VIBE_DEV_AI_TRIAGE=true

# Use mock LLM responses for testing (default: false)
# Set to 'true' to avoid real API calls during testing
VIBE_USE_MOCK_LLM=false

# ============================================================================
# ROLLBACK AND FEATURE FLAGS
# ============================================================================

# Percentage of traffic routed through AI triage (default: 100)
# For gradual rollout: 10, 25, 50, 75, 100
# Only applies when VIBE_AI_ROLLOUT_ENABLED is true
VIBE_AI_ROLLOUT_PERCENTAGE=10

# Enable gradual rollout feature flag (default: false)
# When true, routes only VIBE_AI_ROLLOUT_PERCENTAGE of traffic through AI
VIBE_AI_ROLLOUT_ENABLED=false

# ============================================================================
# COST CONTROL
# ============================================================================

# Daily cost limit in USD (default: 1.0)
# AI triage will stop when this limit is reached
VIBE_DAILY_COST_LIMIT=1.0

# Alert on cost spike (default: 0.5)
# Send alert when daily cost exceeds this amount
VIBE_COST_ALERT_THRESHOLD=0.5

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Memory cache size (default: 1000 entries)
# Maximum number of entries to keep in memory cache
VIBE_MEMORY_CACHE_SIZE=1000

# Connection pool size for HTTP requests (default: 5)
# Number of concurrent connections to Anthropic API
VIBE_CONNECTION_POOL_SIZE=5

# Connection timeout in seconds (default: 10)
# Timeout for establishing connection to API
VIBE_CONNECTION_TIMEOUT=10

# Read timeout in seconds (default: 30)
# Timeout for waiting for API response
VIBE_READ_TIMEOUT=30
